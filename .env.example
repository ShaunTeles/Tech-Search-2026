# Copy this file to .env and fill in your keys
# Get GROQ_API_KEY free at: https://console.groq.com
# Get SERPER_API_KEY free at: https://serper.dev (2,500 searches/month)
# Multiple Serper keys = more coverage (each key gets 2,500 free searches)

GROQ_API_KEY=your_groq_api_key_here
SERPER_API_KEY_1=your_first_serper_key
SERPER_API_KEY_2=your_second_serper_key
SERPER_API_KEY_3=your_third_serper_key
